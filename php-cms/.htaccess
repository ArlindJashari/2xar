<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Dynamic OG tags for details pages
    RewriteRule ^project-detail\.html$ project-detail.php [L,QSA]
    RewriteRule ^news-detail\.html$ news-detail.php [L,QSA]

    # Route /api/ to api/index.php
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^api/(.*)$ api/index.php [L,QSA]

    # Route /admin to admin/index.html
    RewriteCond %{REQUEST_URI} ^/admin/?$ [NC]
    RewriteRule ^ admin/index.html [L]

    # Serve static files directly if they exist
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Clean URLs: map /page to page.html
    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^([^/]+)/?$ $1.html [L]

</IfModule>
